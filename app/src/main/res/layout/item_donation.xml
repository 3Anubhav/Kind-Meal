<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardView"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="5dp"
    android:layout_marginStart="16dp"
    android:layout_marginEnd="16dp"
    android:layout_marginBottom="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/food"
        android:backgroundTint="#88E7E7E7"
        android:padding="16dp">

        <!-- Top Row: Icon + Food Info -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/food_icon"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:src="@drawable/ic_food"
                app:tint="@color/primary_color"
                android:background="@drawable/bg_circle_accent"
                android:padding="8dp"
                android:contentDescription="food_icon_desc"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:paddingStart="16dp">

                <TextView
                    android:id="@+id/food_type"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Food Type"
                    android:textColor="#333333"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvQuantity"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Quantity: 0"
                    android:textColor="#666666"
                    android:textSize="14sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Today"
                android:textColor="#999999"
                android:textSize="12sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvAddedBy"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="RestaurantX"
            android:textSize="14sp"
            android:layout_gravity="end"
            android:textColor="#555555"
            android:layout_marginTop="2dp"
            android:layout_marginBottom="4dp"/>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="12dp"
            android:background="#DDDDDD" />


        <!-- Donation Description Section -->
        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Food Description"
            android:textColor="#000000"
            android:textSize="14sp"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/tvDescription"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textStyle="bold"
            android:text="Description goes here"
            android:textColor="#444444"
            android:textSize="16sp"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/tvStatus"
            android:layout_gravity="end"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pending"
            android:textColor="#FFA000"
            android:textSize="14sp"
            android:layout_marginBottom="8dp" />

</LinearLayout>
    <!-- NGO Action Buttons (visible only when PENDING) -->
    <LinearLayout
        android:id="@+id/ngoActions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end"
        android:visibility="gone"
        android:layout_marginTop="200dp"
        android:layout_marginBottom="8dp"
        android:dividerPadding="10dp">

        <!-- Deny Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDeny"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Deny"
            android:textColor="@color/error_red"
            android:backgroundTint="@color/transparent"
            app:icon="@drawable/ic_close"
            app:iconTint="@color/error_red"
            app:iconPadding="8dp"
            app:cornerRadius="24dp"
            android:elevation="4dp"
            android:layout_marginEnd="10dp"
            android:paddingVertical="10dp"
            android:paddingHorizontal="16dp" />

        <!-- Accept Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAccept"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Accept"
            android:textColor="@color/green_dark"
            android:backgroundTint="@color/transparent"
            app:icon="@drawable/ic_check"
            app:iconTint="@color/green_dark"
            app:iconPadding="8dp"
            app:cornerRadius="24dp"
            android:elevation="4dp"
            android:paddingVertical="10dp"
            android:paddingHorizontal="16dp" />
    </LinearLayout>
    <!--delivery_info-->
    <LinearLayout
        android:id="@+id/delivery_info"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingTop="8dp"
        android:visibility="gone"
        android:layout_marginTop="200dp">

        <TextView
            android:id="@+id/tvDeliveryStatus"
            android:paddingStart="20dp"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="Delivery: NOT SCHEDULED"
            android:textSize="12sp"
            android:textStyle="bold"/>

        <Button
            android:id="@+id/btnSchedule"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Schedule Delivery"
            android:background="@color/transparent"
            android:textColor="@color/green_dark" />


    </LinearLayout>

</androidx.cardview.widget.CardView>
