<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    tools:context=".Home">

<!-- Main content container -->
    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#ffffff"
        android:fitsSystemWindows="true"
        tools:ignore="HardcodedText">


        <!-- Fragment Container for Second Tab -->
        <FrameLayout
            android:id="@+id/fragment_container"
            android:layout_marginTop="10dp"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone"
            app:layout_behavior="@string/appbar_scrolling_view_behavior"/>

        <!-- Scrollable Content -->
        <androidx.core.widget.NestedScrollView
            android:id="@+id/nestedScrollView"
            android:layout_marginTop="-45dp"
            android:layout_width="match_parent"
            android:layout_gravity="top"
            android:layout_height="match_parent"
            app:layout_behavior="@string/appbar_scrolling_view_behavior"
            android:background="#ffffff"
            android:fitsSystemWindows="true"
            android:overScrollMode="ifContentScrolls">
            <!-- Main content container -->
            <LinearLayout
                android:id="@+id/mainContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:gravity="center"
                    android:paddingBottom="40dp"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/toolbar_title"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:text="Kind Meal for Restaurant"
                        android:textColor="@color/green_dark"
                        android:textSize="25sp"
                        android:textStyle="bold"
                        android:textAlignment="center"
                        android:fontFamily="sans-serif-thin"
                        android:layout_marginBottom="4dp"/>

                    <View
                        android:layout_marginTop="20dp"
                        android:layout_width="60dp"
                        android:layout_height="2dp"
                        android:layout_gravity="center"
                        android:background="@color/green_dark" />
                </LinearLayout>


                <!-- Hero Card (Floating) -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/heroCard"
                    android:background="#ffffff"
                    android:backgroundTint="#ffffff"
                    android:layout_width="match_parent"
                    android:layout_height="200dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/card">

                        <TextView
                            android:id="@+id/heroTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="25dp"
                            android:layout_centerHorizontal="true"
                            android:text="Turn Surplus into Smiles"
                            android:textColor="@android:color/white"
                            android:textSize="40sp"
                            android:fontFamily="cursive"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/heroSubtitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_below="@id/heroTitle"
                            android:layout_marginTop="20dp"
                            android:layout_marginBottom="10dp"
                            android:layout_centerHorizontal="true"
                            android:text="Join the movement against food waste"
                            android:textColor="@android:color/white"
                            android:textSize="16sp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/donate_button"
                            android:layout_marginEnd="-10dp"
                            android:textStyle="bold"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentBottom="true"
                            android:layout_alignParentEnd="true"
                            android:text=" Donate Today"
                            android:textSize="18sp"
                            android:fontFamily="sans-serif-light"
                            android:textColor="@color/green_dark"
                            app:backgroundTint="@color/transparent"
                            app:cornerRadius="24dp" />
                    </RelativeLayout>
                </androidx.cardview.widget.CardView>

                <!-- Stats Panel (Floating Circles) -->
                <LinearLayout
                    android:id="@+id/statsPanel"
                    android:layout_width="match_parent"
                    android:layout_height="150dp"
                    android:layout_marginTop="24dp"
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:weightSum="3">

                    <!-- Meals Donated -->
                    <androidx.cardview.widget.CardView
                        android:id="@+id/statsCard1"
                        android:layout_width="0dp"
                        android:layout_height="120dp"
                        android:layout_margin="8dp"
                        android:layout_weight="1"
                        app:cardElevation="0dp"
                        app:cardCornerRadius="20dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@drawable/card1"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/mealsCount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="3dp"
                                android:layout_marginTop="5dp"
                                android:gravity="top|start"
                                android:textColor="@color/yellow_dark"
                                android:textSize="24sp"
                                android:textStyle="bold" />

                            <ImageView
                                android:id="@+id/imageView"
                                android:layout_marginEnd="15dp"
                                android:layout_marginTop="-30dp"
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:layout_gravity="end"
                                app:srcCompat="@drawable/ic_card1"
                                tools:ignore="ContentDescription" />

                            <TextView
                                android:id="@+id/mealsLabel"
                                android:layout_marginTop="18dp"
                                android:layout_gravity="center_horizontal"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Meals Today"
                                android:textColor="@android:color/white"
                                android:textSize="14sp" />
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <!-- Restaurants -->
                    <androidx.cardview.widget.CardView
                        android:id="@+id/statsCard2"
                        android:layout_width="0dp"
                        android:layout_height="120dp"
                        android:layout_margin="8dp"
                        android:layout_weight="1"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="0dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@drawable/card2"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/restaurantsCount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="15dp"
                                android:layout_marginTop="5dp"
                                android:gravity="top|start"
                                android:textColor="@color/green_dark"
                                android:textSize="24sp"
                                android:textStyle="bold" />

                            <ImageView
                                android:id="@+id/imageView1"
                                android:layout_marginEnd="15dp"
                                android:layout_marginTop="-30dp"
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:layout_gravity="end"
                                app:srcCompat="@drawable/ic_card2"
                                tools:ignore="ContentDescription" />

                            <TextView
                                android:id="@+id/restaurantsLabel"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="10dp"
                                android:layout_gravity="center_horizontal"
                                android:text="Restaurants Connected"
                                android:textAlignment="center"
                                android:textColor="@android:color/white"
                                android:textSize="14sp" />
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <!-- NGOs -->
                    <androidx.cardview.widget.CardView
                        android:id="@+id/statsCard3"
                        android:layout_width="0dp"
                        android:layout_height="120dp"
                        android:layout_margin="8dp"
                        android:layout_weight="1"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="0dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@drawable/card3"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/ngosCount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="15dp"
                                android:layout_marginTop="5dp"
                                android:gravity="top|start"
                                android:textColor="@color/blue"
                                android:textSize="24sp"
                                android:textStyle="bold" />

                            <ImageView
                                android:id="@+id/imageView2"
                                android:layout_marginEnd="15dp"
                                android:layout_marginTop="-30dp"
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:layout_gravity="end"
                                app:srcCompat="@drawable/ic_card3"
                                tools:ignore="ContentDescription" />

                            <TextView
                                android:id="@+id/ngosLabel"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="18dp"
                                android:layout_gravity="center_horizontal"
                                android:text="NGOs served"
                                android:textColor="@android:color/white"
                                android:textSize="14sp" />
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>
                </LinearLayout>

                <!-- How It Works Section -->
                <TextView
                    android:id="@+id/howItWorksTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="32dp"
                    android:paddingStart="14dp"
                    android:text="How It Works"
                    android:textColor="@color/blue"
                    android:textSize="20sp"
                    android:fontFamily="sans-serif-condensed-light"
                    android:textStyle="bold"
                    tools:ignore="RtlSymmetry" />

                <!-- Step 1 -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/howItWorksCard1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    app:cardElevation="5dp"
                    app:cardMaxElevation="12dp"
                    app:cardUseCompatPadding="true"
                    app:cardCornerRadius="12dp"
                    app:cardBackgroundColor="@color/white"
                    android:layout_marginHorizontal="2dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="horizontal"
                        android:padding="16dp">

                        <TextView
                            android:id="@+id/step1Number"
                            android:layout_marginTop="5dp"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:background="@drawable/circle1"
                            android:backgroundTint="@color/blue"
                            android:gravity="center"
                            android:text="1"
                            android:textColor="@android:color/white"
                            android:textSize="20sp"
                            android:fontFamily="sans-serif-medium" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:paddingStart="16dp"
                            tools:ignore="RtlSymmetry">

                            <TextView
                                android:id="@+id/step1Title"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Register"
                                android:textColor="@color/blue"
                                android:textSize="16sp"
                                android:fontFamily="sans-serif-condensed-light"
                                android:textStyle="bold"/>

                            <TextView
                                android:id="@+id/step1Description"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Sign up as restaurant or NGO"
                                android:textColor="#666666"
                                android:textSize="14sp" />
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Step 2 -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/howItWorksCard2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="-16dp"
                    app:cardElevation="5dp"
                    app:cardMaxElevation="12dp"
                    app:cardUseCompatPadding="true"
                    app:cardCornerRadius="12dp"
                    app:cardBackgroundColor="@color/white"
                    android:layout_marginHorizontal="2dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="16dp">

                        <TextView
                            android:id="@+id/step2Number"
                            android:layout_marginTop="5dp"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:background="@drawable/circle2"
                            android:backgroundTint="@color/yellow_dark"
                            android:gravity="center"
                            android:text="2"
                            android:textColor="@android:color/white"
                            android:textSize="20sp"
                            android:fontFamily="sans-serif-medium" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:paddingStart="16dp"
                            tools:ignore="RtlSymmetry">

                            <TextView
                                android:id="@+id/step2Title"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Schedule"
                                android:textColor="@color/yellow_dark"
                                android:textSize="16sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/step2Description"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Set pickup/delivery times"
                                android:textColor="#666666"
                                android:textSize="14sp" />
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Step 3 -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/howItWorksCard3"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="-16dp"
                    app:cardElevation="5dp"
                    app:cardMaxElevation="12dp"
                    app:cardUseCompatPadding="true"
                    app:cardCornerRadius="12dp"
                    app:cardBackgroundColor="@color/white"
                    android:layout_marginHorizontal="2dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="16dp">

                        <TextView
                            android:id="@+id/step3Number"
                            android:layout_marginTop="5dp"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:background="@drawable/circle3"
                            android:backgroundTint="@color/green"
                            android:gravity="center"
                            android:text="3"
                            android:textColor="@android:color/white"
                            android:textSize="20sp"
                            android:fontFamily="sans-serif-medium" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:paddingStart="16dp"
                            tools:ignore="RtlSymmetry">

                            <TextView
                                android:id="@+id/step3Title"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Track"
                                android:textColor="@color/green"
                                android:textSize="16sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/step3Description"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Follow donation journey"
                                android:textColor="#666666"
                                android:textSize="14sp" />
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Testimonials Section -->
                <TextView
                    android:id="@+id/testimonialsTitle1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingStart="14dp"
                    android:layout_marginTop="32dp"
                    android:layout_marginBottom="32dp"
                    android:text="Comments from NGOs"
                    android:textColor="@color/green_dark"
                    android:textSize="20sp"
                    android:fontFamily="sans-serif-condensed-light"
                    android:textStyle="bold"
                    tools:ignore="RtlSymmetry" />

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:scrollbars="none"
                    android:fillViewport="true"
                    android:layout_marginBottom="100dp"
                    tools:ignore="RtlSymmetry">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginBottom="15dp">

                        <!-- Testimonial 1 -->
                        <androidx.cardview.widget.CardView
                            android:layout_width="395dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:layout_marginBottom="16dp"
                            app:cardCornerRadius="12dp"
                            app:cardElevation="0dp">

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:padding="16dp"
                                android:background="#F0F0F0">

                                <ImageView
                                    android:layout_width="60dp"
                                    android:layout_height="60dp"
                                    android:src="@drawable/ic_testimonial_1"
                                    android:contentDescription="Restaurant owner testimonial" />

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="vertical"
                                    android:paddingStart="16dp">

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="This app helped us distribute 200+ meals daily!"
                                        android:textColor="#333333"
                                        android:textSize="14sp"
                                        tools:ignore="TooDeepLayout" />

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="4dp"
                                        android:text="- NGO Representative"
                                        android:textColor="#666666"
                                        android:textSize="12sp"
                                        android:textStyle="italic" />
                                </LinearLayout>
                            </LinearLayout>
                        </androidx.cardview.widget.CardView>

                        <!-- Testimonial 2 -->
                        <androidx.cardview.widget.CardView
                            android:layout_width="395dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:layout_marginBottom="16dp"
                            app:cardCornerRadius="12dp"
                            app:cardElevation="0dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:padding="16dp"
                                android:background="#EFEFEF">

                                <ImageView
                                    android:layout_width="60dp"
                                    android:layout_height="60dp"
                                    android:src="@drawable/ic_testimonial_1"
                                    android:contentDescription="Volunteer testimonial" />

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="vertical"
                                    android:paddingStart="16dp">

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Reduced our food waste by 80% while helping the community!"
                                        android:textColor="#333333"
                                        android:textSize="14sp" />

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="4dp"
                                        android:text="- Restaurant Owner"
                                        android:textColor="#666666"
                                        android:textSize="12sp"
                                        android:textStyle="italic" />
                                </LinearLayout>
                            </LinearLayout>
                        </androidx.cardview.widget.CardView>

                        <!-- Testimonial 3 -->
                        <androidx.cardview.widget.CardView
                            android:layout_width="395dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:layout_marginBottom="16dp"
                            app:cardCornerRadius="12dp"
                            app:cardElevation="0dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:padding="16dp"
                                android:background="#EFEFEF">

                                <ImageView
                                    android:layout_width="60dp"
                                    android:layout_height="60dp"
                                    android:src="@drawable/ic_testimonial_1"
                                    android:contentDescription="Community member testimonial" />

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="vertical"
                                    android:paddingStart="16dp">

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="As a volunteer, I've seen firsthand how this changes lives!"
                                        android:textColor="#333333"
                                        android:textSize="14sp" />

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="4dp"
                                        android:text="- Community Volunteer"
                                        android:textColor="#666666"
                                        android:textSize="12sp"
                                        android:textStyle="italic" />
                                </LinearLayout>
                            </LinearLayout>
                        </androidx.cardview.widget.CardView>
                    </LinearLayout>
                </HorizontalScrollView>
            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

        <com.google.android.material.appbar.AppBarLayout
            android:id="@+id/appBar"
            android:layout_marginTop="-15dp"
            android:layout_width="match_parent"
            android:layout_height="0sp"
            android:background="@android:color/transparent"
            android:backgroundTint="@android:color/transparent"
            app:elevation="0dp">

            <androidx.appcompat.widget.Toolbar
                android:id="@+id/toolbar"
                android:layout_width="match_parent"
                android:layout_height="0sp"
                android:background="@android:color/transparent"
                android:backgroundTint="@android:color/transparent"
                app:popupTheme="@style/ThemeOverlay.AppCompat.Light">

            </androidx.appcompat.widget.Toolbar>
        </com.google.android.material.appbar.AppBarLayout>


        <!--Top Button-->
        <ImageButton
            android:id="@+id/fabMenu"
            android:layout_width="50dp"
            android:layout_height="100dp"
            android:layout_marginStart="0dp"
            android:layout_marginTop="0dp"
            android:src="@drawable/ic_menu"
            android:background="@drawable/bg_button_left"
            android:backgroundTint="@color/green_dark"
            app:tint="@color/white"
            android:layout_gravity="start"
            android:scaleType="centerInside"
            android:contentDescription="Menu" />

        <ImageButton
            android:id="@+id/fabSettings"
            android:layout_width="50dp"
            android:layout_height="100dp"
            android:layout_marginStart="0dp"
            android:layout_marginTop="0dp"
            android:src="@drawable/ic_settings"
            android:background="@drawable/bg_button_right"
            android:backgroundTint="@color/green_dark"
            app:tint="@color/white"
            android:layout_gravity="end"
            android:scaleType="centerInside"
            android:contentDescription="Settings"/>

        <!-- Floating Action Button (Add)-->
        <ImageButton
            android:id="@+id/fab"
            android:layout_width="50dp"
            android:layout_height="100dp"
            android:layout_marginBottom="150dp"
            android:src="@drawable/ic_add"
            android:background="@drawable/bg_button_right"
            android:backgroundTint="@color/green_dark"
            app:tint="@color/white"
            android:layout_gravity="bottom|end"
            android:scaleType="centerInside"
            android:contentDescription="Add Donation" />


        <!--Loading Animation-->
        <com.airbnb.lottie.LottieAnimationView
            android:id="@+id/progressBar"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_gravity="center"
            android:visibility="gone"
            app:lottie_autoPlay="true"
            app:lottie_loop="true"
            app:lottie_rawRes="@raw/loading_skeleton"
            app:lottie_colorFilter="@color/green" />


        <!-- Bottom Navigation Bar -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_marginBottom="0dp"
            android:layout_height="120dp"
            android:layout_gravity="bottom"
            android:clipChildren="false"
            android:clipToPadding="false">

            <androidx.compose.ui.platform.ComposeView
                android:id="@+id/composeBottomBar"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipChildren="false"
                android:clipToPadding="false" />
        </FrameLayout>


